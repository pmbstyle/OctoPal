# USER CHANNEL
OCTOPAL_USER_CHANNEL=telegram

# TELEGRAM
TELEGRAM_BOT_TOKEN=
# Comma-separated list of Telegram chat IDs allowed to interact with the octo
ALLOWED_TELEGRAM_CHAT_IDS=
OCTOPAL_TELEGRAM_PARSE_MODE=MarkdownV2

# WHATSAPP
# personal = you message Octopal from the same WhatsApp account you linked
# separate = you link a separate WhatsApp account for Octopal and message it from another number
OCTOPAL_WHATSAPP_MODE=separate
# Comma-separated list of WhatsApp numbers allowed to interact with the octo (E.164)
ALLOWED_WHATSAPP_NUMBERS=
OCTOPAL_WHATSAPP_AUTH_DIR=./data/whatsapp-auth
OCTOPAL_WHATSAPP_BRIDGE_HOST=127.0.0.1
OCTOPAL_WHATSAPP_BRIDGE_PORT=8765
OCTOPAL_WHATSAPP_CALLBACK_TOKEN=
OCTOPAL_WHATSAPP_NODE_COMMAND=node

OCTOPAL_HEARTBEAT_INTERVAL_SECONDS=900

# LLM PROVIDER SELECTION
OCTOPAL_LLM_PROVIDER=litellm
OCTOPAL_LITELLM_PROVIDER_ID=zai
OCTOPAL_LITELLM_MODEL=glm-5
OCTOPAL_LITELLM_API_KEY=
OCTOPAL_LITELLM_API_BASE=https://api.z.ai/api/coding/paas/v4
OCTOPAL_LITELLM_MODEL_PREFIX=openai

# LEGACY OPENROUTER COMPATIBILITY
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4
OPENROUTER_TIMEOUT=120

# LEGACY Z.AI COMPATIBILITY
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
ZAI_CHAT_PATH=/chat/completions
ZAI_TIMEOUT_SECONDS=45
ZAI_CONNECT_TIMEOUT_SECONDS=15
ZAI_ACCEPT_LANGUAGE=en-US,en
ZAI_MODEL=glm-5

# LITELLM TRANSPORT
LITELLM_NUM_RETRIES=3
LITELLM_TIMEOUT=120
LITELLM_FALLBACKS=
LITELLM_DROP_PARAMS=1
LITELLM_CACHING=0
LITELLM_MAX_CONCURRENCY=2
LITELLM_RATE_LIMIT_MAX_RETRIES=6
LITELLM_RATE_LIMIT_BASE_DELAY_SECONDS=1.0
LITELLM_RATE_LIMIT_MAX_DELAY_SECONDS=30.0

# EMBEDDINGS (SEMANTIC MEMORY)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBED_MODEL=text-embedding-3-small

# TOOLS
BRAVE_API_KEY=
FIRECRAWL_API_KEY=

# RUNTIME
OCTOPAL_STATE_DIR=./data
OCTOPAL_WORKSPACE_DIR=./workspace
OCTOPAL_LOG_LEVEL=INFO
OCTOPAL_DEBUG_PROMPTS=0

# MEMORY
OCTOPAL_MEMORY_TOP_K=5
OCTOPAL_MEMORY_PREFILTER_K=80
OCTOPAL_MEMORY_MIN_SCORE=0.25
OCTOPAL_MEMORY_MAX_CHARS=2000
OCTOPAL_MEMORY_OWNER_ID=default

# GATEWAY / DASHBOARD
OCTOPAL_GATEWAY_HOST=0.0.0.0
OCTOPAL_GATEWAY_PORT=8000
OCTOPAL_TAILSCALE_IPS=
OCTOPAL_DASHBOARD_TOKEN=
OCTOPAL_TAILSCALE_AUTO_SERVE=1
OCTOPAL_WEBAPP_ENABLED=0
# OCTOPAL_WEBAPP_DIST_DIR=webapp/dist

# WORKER LAUNCHER
OCTOPAL_WORKER_LAUNCHER=same_env
OCTOPAL_WORKER_DOCKER_IMAGE=octopal-worker:latest
OCTOPAL_WORKER_DOCKER_WORKSPACE=/workspace
OCTOPAL_WORKER_DOCKER_HOST_WORKSPACE=
OCTOPAL_WORKER_MAX_SPAWN_DEPTH=2
OCTOPAL_WORKER_MAX_CHILDREN_TOTAL=20
OCTOPAL_WORKER_MAX_CHILDREN_CONCURRENT=10
OCTOPAL_TOOL_LOOP_WARNING_THRESHOLD=8
OCTOPAL_TOOL_LOOP_CRITICAL_THRESHOLD=12
OCTOPAL_TOOL_LOOP_GLOBAL_BREAKER_THRESHOLD=30
