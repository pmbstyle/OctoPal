TELEGRAM_BOT_TOKEN=
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
ZAI_CHAT_PATH=/chat/completions
ZAI_TIMEOUT_SECONDS=45
ZAI_CONNECT_TIMEOUT_SECONDS=15
ZAI_ACCEPT_LANGUAGE=en-US,en
BRAVE_API_KEY=
ZAI_MODEL=glm-4.7
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBED_MODEL=text-embedding-3-small
BROODMIND_STATE_DIR=./data
BROODMIND_WORKSPACE_DIR=./workspace
BROODMIND_LOG_LEVEL=INFO
BROODMIND_MEMORY_TOP_K=5
BROODMIND_MEMORY_MIN_SCORE=0.25
BROODMIND_MEMORY_MAX_CHARS=2000
BROODMIND_GATEWAY_HOST=0.0.0.0
BROODMIND_GATEWAY_PORT=8000
BROODMIND_WORKER_LAUNCHER=same_env
BROODMIND_WORKER_DOCKER_IMAGE=broodmind-worker:latest
BROODMIND_WORKER_DOCKER_WORKSPACE=/workspace
BROODMIND_WORKER_DOCKER_HOST_WORKSPACE=
